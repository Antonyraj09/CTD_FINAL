@using CTD_FINAL.Entities
@{
    ViewData["Title"] = "Customer Dashboard";
    var importers = (List<Importer>)ViewBag.Importers;
    var selectedId = (int)ViewBag.SelectedImporterId;
}
<div class="section-head">
    <div>
        <h2>Customer Dashboard</h2>
        <p>Self-service shipment visibility for importers &amp; consignees</p>
    </div>
    <div class="section-actions">
        <div class="field" style="min-width:240px;margin:0;">
            <select id="custSelector">
                @foreach (var i in importers)
                {
                    <option value="@i.Id" selected="@(i.Id == selectedId)">@i.Name</option>
                }
            </select>
        </div>
    </div>
</div>

<div class="kpi-grid" id="custKpiGrid" style="grid-template-columns:repeat(4,1fr);"></div>

<div class="dash-grid">
    <div class="panel">
        <div class="panel-head"><h3><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>My Active Shipments</h3></div>
        <div class="table-scroll">
            <table class="data-table">
                <thead><tr><th>Job No.</th><th>CTD No.</th><th>Container</th><th>Border Point</th><th>Status</th><th>ETA Nepal</th></tr></thead>
                <tbody id="custShipmentsBody"></tbody>
            </table>
        </div>
    </div>
    <div class="panel">
        <div class="panel-head"><h3><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>Billing Snapshot</h3></div>
        <div class="panel-body">
            <div id="custBillingBody"></div>
        </div>
    </div>
</div>

<div class="panel" style="margin-top:18px;">
    <div class="panel-head"><h3><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>Latest Shipment Timeline</h3>
        <div class="field" style="margin:0;min-width:200px;"><select id="custTimelineJobSelect"></select></div>
    </div>
    <div class="panel-body">
        <div class="timeline" id="custTimelineBody"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/customer-dashboard.js" asp-append-version="true"></script>
}
