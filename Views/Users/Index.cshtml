@using CTD_FINAL.Entities
@using CTD_FINAL.Constants
@{
    ViewData["Title"] = "Users & Roles";
    var users = (List<(ApplicationUser User, string Role)>)ViewBag.Users;
    var roles = (string[])ViewBag.Roles;
    var modules = ((string Key, string Label)[])ViewBag.PermissionModules;
    var matrix = (Dictionary<string, Dictionary<string, bool>>)ViewBag.Matrix;
}
<div class="section-head">
    <div>
        <h2>Users &amp; Role-Based Permissions</h2>
        <p>Control what each role can see and do inside the system</p>
    </div>
    <div class="section-actions">
        <button class="btn btn-amber btn-sm" id="addUserBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
            Add User
        </button>
    </div>
</div>

<div class="panel" style="margin-bottom:18px;">
    <div class="table-scroll">
        <table class="data-table">
            <thead><tr><th>User</th><th>Email</th><th>Role</th><th>Status</th><th>Last Login</th><th class="no-print">Actions</th></tr></thead>
            <tbody id="usersTableBody">
                @foreach (var (user, role) in users)
                {
                    <tr data-id="@user.Id">
                        <td class="cell-strong">@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@role</td>
                        <td><span class="badge @(user.IsActive ? "badge-delivered" : "badge-pending")">@(user.IsActive ? "Active" : "Inactive")</span></td>
                        <td>@(user.LastLoginAt?.ToString("d MMM yyyy, h:mm tt") ?? "—")</td>
                        <td class="no-print">
                            <div class="row-actions">
                                <button class="iconbtn-table" data-user-edit="@user.Id" title="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></button>
                                <button class="iconbtn-table" data-user-reset="@user.Id" title="Reset Password"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg></button>
                                <button class="iconbtn-table @(user.IsActive ? "danger" : "")" data-user-toggle="@user.Id" title="@(user.IsActive ? "Disable" : "Enable")">
                                    @if (user.IsActive)
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.9" y1="4.9" x2="19.1" y2="19.1"/></svg>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
                                    }
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="panel">
    <div class="panel-head"><h3>Role Permission Matrix</h3></div>
    <form id="permMatrixForm">
        <div class="table-scroll">
            <table class="data-table perm-table" id="permTable">
                <thead>
                    <tr>
                        <th>Module / Action</th>
                        @foreach (var role in roles)
                        {
                            <th>@role</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (key, label) in modules)
                    {
                        <tr>
                            <td class="cell-strong">@label</td>
                            @foreach (var role in roles)
                            {
                                var allowed = matrix.TryGetValue(role, out var m) && m.TryGetValue(key, out var a) && a;
                                <td style="text-align:center;">
                                    <input type="checkbox" name="perm_@(role)_@(key)" @(allowed ? "checked" : "") />
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="modal-foot" style="justify-content:flex-end;">
            <button type="submit" class="btn btn-primary btn-sm" id="savePermBtn">Save Permission Matrix</button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/users.js" asp-append-version="true"></script>
}
