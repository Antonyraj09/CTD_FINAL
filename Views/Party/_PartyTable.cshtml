@using CTD_FINAL.Entities
@model IReadOnlyList<Party>
@{
    string RoleBadge(string role) => role switch
    {
        "Importer" => "badge-approved",
        "Transporter" => "badge-transit",
        "Agent" => "badge-submitted",
        _ => "badge-draft"
    };
}
<table class="data-table" id="partyTable">
    <thead>
        <tr>
            <th>Code</th>
            <th>Party Name</th>
            <th>Role(s)</th>
            <th>PAN / IEC</th>
            <th>Primary Branch</th>
            <th>GSTIN</th>
            <th>Status</th>
            <th class="no-print">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="8" class="table-empty">No parties found</td></tr>
        }
        else
        {
            foreach (var p in Model)
            {
                var primary = p.Branches.FirstOrDefault(b => b.IsPrimary) ?? p.Branches.FirstOrDefault();
                <tr data-id="@p.Id">
                    <td>@(p.PartyCode ?? "—")</td>
                    <td class="cell-strong">
                        @p.Name
                        @if (!string.IsNullOrEmpty(p.TradeName))
                        {
                            <span style="display:block;font-size:11px;color:var(--ink-400);font-weight:400;">trading as @p.TradeName</span>
                        }
                    </td>
                    <td>
                        @foreach (var role in p.Roles.Split(", ", StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="badge @RoleBadge(role)" style="margin-right:4px;">@role</span>
                        }
                    </td>
                    <td>
                        @(p.Pan ?? "—")<br>
                        <span style="font-size:11px;color:var(--ink-400);">@(p.IecCode ?? "—")</span>
                    </td>
                    <td>
                        @if (primary is null)
                        {
                            <span class="text-muted">No branch</span>
                        }
                        else
                        {
                            @primary.BranchName @: — @primary.City
                        }
                    </td>
                    <td>@(primary?.Gstin ?? "—")</td>
                    <td><span class="badge @(p.IsActive ? "badge-delivered" : "badge-draft")">@(p.IsActive ? "Active" : "Inactive")</span></td>
                    <td class="no-print">
                        <div class="row-actions">
                            <a class="iconbtn-table" asp-controller="Party" asp-action="Edit" asp-route-id="@p.Id" title="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></a>
                            <button class="iconbtn-table danger" data-party-delete="@p.Id" data-party-name="@p.Name" title="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2"/></svg></button>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
