@using CTD_FINAL.Interfaces
@using CTD_FINAL.Constants
@inject IPermissionService PermissionService
@{
    var role = User.IsInRole(RoleNames.Administrator) ? RoleNames.Administrator
        : User.IsInRole(RoleNames.Manager) ? RoleNames.Manager
        : User.IsInRole(RoleNames.Operator) ? RoleNames.Operator
        : RoleNames.Viewer;

    var matrix = await PermissionService.GetMatrixAsync();
    bool Can(string key) => matrix.TryGetValue(role, out var m) && m.TryGetValue(key, out var a) && a;

    string activeNav = ViewData["ActiveNav"] as string ?? "";
    string activeModule = ViewData["ActiveModule"] as string ?? "";
    string NavClass(string slug) => "sidebar-link" + (activeNav == slug ? " active" : "");
    string ModuleClass(string key) => "erp-module" + (activeModule == key ? " open" : "");
    string ModuleHeaderClass(string key) => "erp-module-header" + (activeModule == key ? " module-active" : "");
}
<aside class="sidebar" id="sidebar">
