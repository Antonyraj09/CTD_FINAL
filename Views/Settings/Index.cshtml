@model CTD_FINAL.Models.Settings.SettingsFormViewModel
@{
    ViewData["Title"] = "Settings";
    var isAdmin = User.IsInRole(CTD_FINAL.Constants.RoleNames.Administrator);
}
<div class="section-head">
    <div><h2>Settings</h2><p>System preferences and numbering configuration</p></div>
</div>

<form id="settingsForm" asp-controller="Settings" asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <div class="grid-2">
        <div class="panel">
            <div class="panel-head"><h3>Document Number Auto-Generation</h3></div>
            <div class="panel-body">
                <div class="form-grid cols-2">
                    <div class="field"><label>Job Number Prefix</label><input asp-for="JobNumberPrefix" disabled="@(!isAdmin)"></div>
                    <div class="field"><label>Job Number Format</label><div class="field-static">PREFIX-YYYY-SEQ (4 digit)</div></div>
                    <div class="field"><label>Invoice Prefix</label><input asp-for="InvoicePrefix" disabled="@(!isAdmin)"></div>
                    <div class="field"><label>Document Prefix</label><input asp-for="DocumentPrefix" disabled="@(!isAdmin)"></div>
                </div>
                @if (isAdmin)
                {
                    <button type="submit" class="btn btn-primary btn-sm" style="margin-top:10px;" id="saveSettingsBtn">Save Settings</button>
                }
            </div>
        </div>
        <div class="panel">
            <div class="panel-head"><h3>Company Profile</h3></div>
            <div class="panel-body">
                <div class="form-grid cols-2">
                    <div class="field span-2"><label>Company Name</label><input asp-for="CompanyName" disabled="@(!isAdmin)"></div>
                    <div class="field span-2"><label>Address</label><input asp-for="CompanyAddress" disabled="@(!isAdmin)"></div>
                    <div class="field"><label>GSTIN</label><input asp-for="CompanyGstin" disabled="@(!isAdmin)"></div>
                    <div class="field"><label>CHA License No.</label><input asp-for="ChaLicenseNo" disabled="@(!isAdmin)"></div>
                </div>
                @if (!isAdmin)
                {
                    <p style="margin:12px 0 0;font-size:12px;color:var(--ink-500);">Only Administrators can edit system settings.</p>
                }
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/settings.js" asp-append-version="true"></script>
}
