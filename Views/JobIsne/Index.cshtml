@using CTD_FINAL.Entities
@model CTD_FINAL.Entities.JobIsne?
@{
    ViewData["Title"] = Model is null ? "Job — ISNE (New)" : $"Job — ISNE ({Model.JobNumber})";
    string jobNumber = (string)ViewBag.NextJobNumber;
    string D(DateTime? d) => d?.ToString("yyyy-MM-dd") ?? "";
    string today = DateTime.Today.ToString("yyyy-MM-dd");

    var parties = (List<Party>)ViewBag.Parties;
    var subAgents = (List<SubAgent>)ViewBag.SubAgents;
    var transitRoutes = (List<TransitRoute>)ViewBag.TransitRoutes;

    // Client-side lookup data for the Party Code cascade (Party Name / Address / Sub-Agent
    // auto-fill) — see wwwroot/js/job-isne.js. Party has no FK from JobIsne (free-text tag,
    // same convention as PartyName/SubAgentCode elsewhere), so the lookup happens client-side
    // against this embedded blob rather than a server round-trip.
    var partyLookup = parties.Where(p => !string.IsNullOrEmpty(p.PartyCode)).Select(p => new
    {
        code = p.PartyCode,
        name = p.Name,
        subAgentCode = p.SubAgentCode,
        branches = p.Branches.OrderByDescending(b => b.IsPrimary).Select(b => new
        {
            id = b.Id,
            label = b.BranchName,
            address = string.Join(", ", new[] { b.AddressLine1, b.AddressLine2, b.City, b.State, b.PinCode, b.Country }.Where(s => !string.IsNullOrWhiteSpace(s)))
        }).ToList()
    }).ToList();
    var subAgentLookup = subAgents.Select(s => new { code = s.SubAgentCode, name = s.Name }).ToList();

    var containerInit = Model != null && Model.Containers.Any()
        ? Model.Containers.Select(c => new
        {
            containerNo = c.ContainerNo,
            containerSize = c.ContainerSize,
            shipmentType = c.ShipmentType.ToString(),
            noPackages = c.NoPackages,
            packageType = c.PackageType,
            grossWeight = c.GrossWeight,
            grossWeightUnit = c.GrossWeightUnit,
            netWeight = c.NetWeight,
            netWeightUnit = c.NetWeightUnit,
            marksSerial = c.MarksSerial,
            customsCode = c.CustomsCode
        })
        : new[] { new
        {
            containerNo = (string?)"",
            containerSize = "20ft",
            shipmentType = "FCL",
            noPackages = 0,
            packageType = (string?)"",
            grossWeight = (decimal?)null,
            grossWeightUnit = "KG",
            netWeight = (decimal?)null,
            netWeightUnit = "KG",
            marksSerial = (string?)"",
            customsCode = (string?)""
        } };
}

<div class="erp-form-header">
    <div class="erp-form-title">
        <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--amber-500),var(--amber-600));display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#1a1305" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <div>
            <h2>JOB — ISNE</h2>
            <div style="font-size:11.5px;color:#aab4cc;margin-top:2px;">Import Sea / Nepal Entry &nbsp;·&nbsp; Press F9 to Save</div>
        </div>
        <span>ISNE Entry</span>
    </div>
    <div class="erp-form-actions">
        <button class="btn btn-outline btn-sm" id="isneNewBtn" style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.14);color:#e6e9f2;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg> New
        </button>
        <button class="btn btn-amber btn-sm" id="isneSaveBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save (F9)
        </button>
        <button class="btn btn-outline btn-sm" id="isneEditBtn" style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.14);color:#e6e9f2;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg> Edit
        </button>
        <button class="btn btn-danger btn-sm" id="isneDeleteBtn" @(Model is null ? "disabled" : "")>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg> Delete
        </button>
        <button class="btn btn-outline btn-sm" id="isnePrintBtn" style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.14);color:#e6e9f2;" @(Model is null ? "disabled" : "")>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg> Print
        </button>
        <button class="btn btn-outline btn-sm" id="isneCtdSubmissionBtn" title="Print the ANNEXURE-A data sheet for Nepal customs CTD submission" style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.14);color:#e6e9f2;" @(Model is null ? "disabled" : "")>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg> CTD Submission (Nepal)
        </button>
        <button class="btn btn-ghost btn-sm" id="isneCancelBtn" style="color:#aab4cc;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Cancel
        </button>
    </div>
</div>

<form id="isneForm" data-record-id="@(Model?.Id ?? 0)">
<div class="erp-form-body">

    <!-- ============ SECTION A: JOB INFORMATION ============ -->
    <div class="erp-section">
        <div class="erp-section-head">
            <div class="section-letter">A</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            Job Information
        </div>
        <div class="erp-section-body">
            <div class="form-grid cols-4">
                <div class="field">
                    <label>Job Number <span class="req">*</span></label>
                    <div class="field-static" id="isne_jobNumber">@jobNumber</div>
                </div>
                <div class="field">
                    <label>Job Date <span class="req">*</span></label>
                    <input type="date" id="isne_jobDate" value="@(Model is null ? today : D(Model.JobDate))">
                </div>
                <div class="field">
                    <label>Party Code <span class="req">*</span></label>
                    <select id="isne_partyCode">
                        <option value="">-- Select Party --</option>
                        @foreach (var p in parties.Where(p => !string.IsNullOrEmpty(p.PartyCode)))
                        {
                            <option value="@p.PartyCode" selected="@(Model != null && Model.PartyCode == p.PartyCode)">@p.PartyCode — @p.Name</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Party Name <span class="req">*</span></label>
                    <input type="text" id="isne_partyName" placeholder="Importer / Consignee Name" value="@Model?.PartyName">
                </div>
                <div class="field" id="isne_branchField" style="display:none;">
                    <label>Branch <span style="font-weight:400;color:var(--ink-400);">(multiple on file)</span></label>
                    <select id="isne_branchSelect"></select>
                </div>
                <div class="field span-2">
                    <label>Address</label>
                    <textarea id="isne_address" placeholder="Full address of the party" style="min-height:60px;">@Model?.Address</textarea>
                </div>
                <div class="field">
                    <label>Sub Agent Code</label>
                    <input type="text" id="isne_subAgentCode" placeholder="e.g. BR000" value="@Model?.SubAgentCode">
                </div>
                <div class="field">
                    <label>Sub Agent Name</label>
                    <input type="text" id="isne_subAgentName" placeholder="Sub Agent / Transporter" value="@Model?.SubAgentName">
                </div>
                <div class="field">
                    <label>CTD Number</label>
                    <input type="text" id="isne_ctdNumber" placeholder="CTD / Transit Number (25 alphanumeric)" value="@Model?.CtdNumber">
                </div>
                <div class="field">
                    <label>CTD Date</label>
                    <input type="date" id="isne_ctdDate" value="@D(Model?.CtdDate)">
                </div>
                <div class="field">
                    <label>Vessel Name</label>
                    <input type="text" id="isne_vesselName" placeholder="e.g. KOTA RIA" maxlength="30" value="@Model?.VesselName">
                </div>
                <div class="field">
                    <label>Voyage Number</label>
                    <input type="text" id="isne_voyageNo" placeholder="e.g. 0590W" value="@Model?.VoyageNo">
                </div>
                <div class="field">
                    <label>Transshipment Vessel</label>
                    <input type="text" id="isne_tsVessel" placeholder="T/S Vessel Name" maxlength="30" value="@Model?.TsVessel">
                </div>
                <div class="field">
                    <label>T/S Vessel Voyage</label>
                    <input type="text" id="isne_tsVoyage" placeholder="e.g. KRIA0590E" value="@Model?.TsVoyage">
                </div>
                <div class="field">
                    <label>Country of CGN</label>
                    <input type="text" id="isne_countryCGN" placeholder="e.g. China" value="@Model?.CountryCgn">
                </div>
                <div class="field">
                    <label>Country of Origin</label>
                    <input type="text" id="isne_countryOrigin" placeholder="e.g. India" value="@Model?.CountryOrigin">
                </div>
                <div class="field">
                    <label>Route of Transit</label>
                    <select id="isne_rot">
                        <option value="">-- Select Route --</option>
                        @foreach (var r in transitRoutes)
                        {
                            <option value="@r.Name" selected="@(Model != null && Model.RouteOfTransit == r.Name)">@r.Name</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label>ROT Number</label>
                    <input type="text" id="isne_rotNo" placeholder="ROT Reference No." value="@Model?.RotNo">
                </div>
                <div class="field">
                    <label>ROT Date</label>
                    <input type="date" id="isne_rotDate" value="@D(Model?.RotDate)">
                </div>
                <div class="field">
                    <label>Inward Date</label>
                    <input type="date" id="isne_inwardDate" value="@D(Model?.InwardDate)">
                </div>
                <div class="field">
                    <label>Line Number</label>
                    <input type="text" id="isne_lineNo" placeholder="Line No." value="@Model?.LineNo">
                </div>
            </div>
        </div>
    </div>

    <script id="isnePartyLookupData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(partyLookup))</script>
    <script id="isneSubAgentLookupData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(subAgentLookup))</script>

    <!-- ============ SECTION B: DOCUMENT INFORMATION ============ -->
    <div class="erp-section">
        <div class="erp-section-head">
            <div class="section-letter">B</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
            Document Information
        </div>
        <div class="erp-section-body">
            <div class="form-grid cols-4">
                <div class="field"><label>Master Bill Number</label><input type="text" id="isne_mblNo" placeholder="e.g. SZXCB26022302" value="@Model?.MblNo"></div>
                <div class="field"><label>Master Bill Date</label><input type="date" id="isne_mblDate" value="@D(Model?.MblDate)"></div>
                <div class="field"><label>House Bill Number</label><input type="text" id="isne_hblNo" placeholder="House B/L Number" value="@Model?.HblNo"></div>
                <div class="field"><label>House Bill Date</label><input type="date" id="isne_hblDate" value="@D(Model?.HblDate)"></div>
                <div class="field"><label>Import License Number</label><input type="text" id="isne_ilNo" placeholder="Import License No." value="@Model?.IlNo"></div>
                <div class="field"><label>Import License Date</label><input type="date" id="isne_ilDate" value="@D(Model?.IlDate)"></div>
                <div class="field"><label>Letter of Credit Number</label><input type="text" id="isne_lcNo" placeholder="e.g. LC:HBLIFX03821256" value="@Model?.LcNo"></div>
                <div class="field"><label>LC Date</label><input type="date" id="isne_lcDate" value="@D(Model?.LcDate)"></div>
                <div class="field span-2"><label>Account Name</label><input type="text" id="isne_accountName" placeholder="e.g. DIRECT" value="@Model?.AccountName"></div>
                <div class="field span-2"><label>Bank Name &amp; Branch</label><input type="text" id="isne_bankName" placeholder="e.g. TO ORDER OF HIMALAYAN BANK LTD" value="@Model?.BankName"></div>
                <div class="field"><label>Reference Number</label><input type="text" id="isne_refNo" placeholder="Reference Number" value="@Model?.RefNo"></div>
                <div class="field"><label>Reference Date</label><input type="date" id="isne_refDate" value="@D(Model?.RefDate)"></div>
                <div class="field"><label>Steamer Agent</label><input type="text" id="isne_steamerAgent" placeholder="e.g. CHAKIAT" value="@Model?.SteamerAgent"></div>
                <div class="field"><label>Container Agent</label><input type="text" id="isne_containerAgent" placeholder="e.g. CHAKIAT STEVE" value="@Model?.ContainerAgent"></div>
            </div>
        </div>
    </div>

    <!-- ============ SECTION C: TRANSIT & DELIVERY DETAILS ============ -->
    <div class="erp-section">
        <div class="erp-section-head">
            <div class="section-letter">C</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Transit &amp; Delivery Details
        </div>
        <div class="erp-section-body">
            <div class="form-grid cols-4">
                <div class="field"><label>Vessel Arrival Date</label><input type="date" id="isne_vesselArrival" value="@D(Model?.VesselArrival)"></div>
                <div class="field"><label>CTD Sent To</label><input type="text" id="isne_ctdSentTo" placeholder="Destination / Custom Office" value="@Model?.CtdSentTo"></div>
                <div class="field">
                    <label>Green CTD</label>
                    <div class="toggle-field" style="padding-top:10px;">
                        <label class="toggle-switch">
                            <input type="checkbox" id="isne_greenCtd" checked="@(Model?.GreenCtd == true)">
                            <span class="toggle-slider"></span>
                        </label>
                        <span class="toggle-label">Green CTD</span>
                    </div>
                </div>
                <div class="field"></div>
                <div class="field"><label>Due — Packing List Date</label><input type="date" id="isne_duePackingList" value="@D(Model?.DuePackingList)"></div>
                <div class="field"><label>Due — Invoice Date</label><input type="date" id="isne_dueInvoice" value="@D(Model?.DueInvoice)"></div>
                <div class="field"><label>Due — Original B/L Date</label><input type="date" id="isne_dueOriginalBL" value="@D(Model?.DueOriginalBl)"></div>
                <div class="field"><label>Due — Insurance Certificate</label><input type="date" id="isne_dueInsuranceCert" value="@D(Model?.DueInsuranceCert)"></div>
                <div class="field"><label>Due — LC Copy Date</label><input type="date" id="isne_dueLcCopy" value="@D(Model?.DueLcCopy)"></div>
                <div class="field"><label>Due — LOA Date</label><input type="date" id="isne_dueLoa" value="@D(Model?.DueLoa)"></div>
                <div class="field"><label>Due — Certificate of Origin</label><input type="date" id="isne_dueOrigin" value="@D(Model?.DueOrigin)"></div>
                <div class="field"><label>Due — Proforma Invoice</label><input type="date" id="isne_dueProformaInvoice" value="@D(Model?.DueProformaInvoice)"></div>
            </div>
        </div>
    </div>

    <!-- ============ SECTION D: CONTAINER & CARGO DETAILS ============ -->
    <div class="erp-section">
        <div class="erp-section-head">
            <div class="section-letter">D</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
            Container &amp; Cargo Details
        </div>
        <div class="erp-section-body">
            <div class="split-grid">
                <div class="split-panel">
                    <div class="split-panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
                        Shipment Information
                    </div>
                    <div class="field">
                        <label>Shipment Type <span class="req">*</span></label>
                        <div class="radio-group">
                            <label class="radio-pill @(Model is null || Model.ShipmentType == CTD_FINAL.Enums.ContainerStatus.FCL ? "checked" : "")" id="rp_shiptype_fcl">
                                <input type="radio" name="isneShipmentType" value="FCL" checked="@(Model is null || Model.ShipmentType == CTD_FINAL.Enums.ContainerStatus.FCL)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/></svg>
                                FCL
                            </label>
                            <label class="radio-pill @(Model?.ShipmentType == CTD_FINAL.Enums.ContainerStatus.LCL ? "checked" : "")" id="rp_shiptype_lcl">
                                <input type="radio" name="isneShipmentType" value="LCL" checked="@(Model?.ShipmentType == CTD_FINAL.Enums.ContainerStatus.LCL)">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                                LCL
                            </label>
                        </div>
                    </div>
                    <div class="form-grid cols-2" style="gap:14px;margin-top:14px;align-items:end;">
                        <div class="field">
                            <label>No. of Containers <span class="req">*</span></label>
                            <input type="number" id="isne_containerCount" placeholder="e.g. 10" min="0" max="200" step="1" value="@(Model?.Containers.Count ?? 1)">
                        </div>
                        <div class="field">
                            <button type="button" class="btn btn-amber" id="isneGenerateContainersBtn" style="width:100%;justify-content:center;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 3v18M3 12h18"/></svg>
                                Generate Containers
                            </button>
                        </div>
                    </div>
                    <p style="font-size:11.5px;color:var(--ink-500);margin-top:6px;">Enter number of containers and click Generate.</p>
                </div>
                <div class="split-panel">
                    <div class="split-panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        Common Cargo Details <span style="font-weight:500;color:var(--ink-500);font-size:11.5px;">(Applies to all containers)</span>
                    </div>
                    <div class="form-grid cols-2" style="gap:14px;">
                        <div class="field"><label>Miscellaneous Description</label><textarea id="isne_miscDesc" placeholder="e.g. SHIPPER'S LOAD &amp; COUNT" style="min-height:96px;">@Model?.MiscDescription</textarea></div>
                        <div class="field"><label>Cargo Description</label><textarea id="isne_cargoDesc" placeholder="e.g. STAINLESS STEEL COLD ROLLED COILS GRADE 201/302 FINISHED MILL EDGE" style="min-height:96px;">@Model?.CargoDescription</textarea></div>
                    </div>
                </div>
            </div>

            <div class="split-panel" style="margin-top:18px;">
                <div class="flex-between" style="margin-bottom:12px;flex-wrap:wrap;gap:10px;">
                    <div class="split-panel-title" style="margin:0;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
                        Container Details
                    </div>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;">
                        <button type="button" class="btn btn-outline btn-xs" id="isneImportExcelBtn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 3-3 3 3M12 12v6"/></svg>
                            Import from Excel
                        </button>
                        <input type="file" id="isneExcelFileInput" accept=".csv,.txt" hidden>
                        <button type="button" class="btn btn-outline btn-xs" id="isneClearAllBtn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                            Clear All
                        </button>
                    </div>
                </div>
                <div class="table-scroll">
                    <table class="mini-table" id="isneContainerTable">
                        <thead>
                            <tr>
                                <th style="width:28px;"><input type="checkbox" id="isneSelectAllRows" style="width:16px;height:16px;padding:0;accent-color:var(--amber-500);"></th>
                                <th style="width:34px;">S.No</th>
                                <th style="min-width:140px;">Container No. <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:90px;">Size <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:100px;">Shipment Type <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:80px;">Packages <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:110px;">Package Type <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:100px;">Gross Weight <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:70px;">Unit</th>
                                <th style="min-width:100px;">Net Weight <span style="color:var(--seal-red);">*</span></th>
                                <th style="min-width:70px;">Unit</th>
                                <th style="min-width:140px;">Marks &amp; Serial No.</th>
                                <th style="min-width:130px;">Customs Code</th>
                                <th style="width:36px;"></th>
                            </tr>
                        </thead>
                        <tbody id="isneContainerRowsBody"></tbody>
                    </table>
                </div>
                <div class="flex-between" style="margin-top:12px;">
                    <button type="button" class="btn btn-outline btn-xs" id="isneAddContainerBtn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                        Add Container
                    </button>
                    <button type="button" class="btn btn-danger btn-xs" id="isneRemoveSelectedBtn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2"/></svg>
                        Remove Selected
                    </button>
                </div>
            </div>
        </div>
    </div>
    <script id="isneContainerDataInit" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(containerInit))</script>

    <!-- ============ SECTION E: COMMERCIAL INFORMATION ============ -->
    <div class="erp-section">
        <div class="erp-section-head">
            <div class="section-letter">E</div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Commercial Information
        </div>
        <div class="erp-section-body">
            <div class="fin-grid">
                <div class="fin-group-title">Currency &amp; Values</div>
                <div class="field">
                    <label>Unit of Currency</label>
                    <select id="isne_currency">
                        @foreach (var c in new[] { ("USD","USD — US Dollar"),("EUR","EUR — Euro"),("GBP","GBP — British Pound"),("JPY","JPY — Japanese Yen"),("CNY","CNY — Chinese Yuan"),("INR","INR — Indian Rupee"),("SGD","SGD — Singapore Dollar"),("AUD","AUD — Australian Dollar") })
                        {
                            <option value="@c.Item1" selected="@((Model?.Currency ?? "USD") == c.Item1)">@c.Item2</option>
                        }
                    </select>
                </div>
                <div class="field"><label>Exchange Rate</label><div class="field-suffix-wrap"><input type="number" id="isne_exchangeRate" placeholder="0.0000" step="0.0001" value="@Model?.ExchangeRate"><span class="field-suffix">₹</span></div></div>
                <div class="field"><label>FOB Value</label><div class="field-suffix-wrap"><input type="number" id="isne_fobValue" placeholder="0.00" step="0.01" value="@Model?.FobValue"><span class="field-suffix" id="isne_fobSuffix">FC</span></div></div>
                <div class="field"><label>Freight</label><div class="field-suffix-wrap"><input type="number" id="isne_freight" placeholder="0.00" step="0.01" value="@Model?.Freight"><span class="field-suffix" id="isne_freightSuffix">FC</span></div></div>
                <div class="field"><label>CIF Value (FC)</label><div class="field-suffix-wrap"><input type="number" id="isne_cifFC" placeholder="0.00" step="0.01" value="@Model?.CifFc"><span class="field-suffix">FC</span></div></div>
                <div class="field"><label>CIF Value FC (Reference)</label><div class="field-suffix-wrap"><input type="number" id="isne_cifFCRef" placeholder="0.00" step="0.01" value="@Model?.CifFcReference"><span class="field-suffix">FC</span></div></div>
                <div class="field"><label>Insurance in Foreign Currency</label><div class="field-suffix-wrap"><input type="number" id="isne_insFC" placeholder="0.00" step="0.01" value="@Model?.InsuranceFc"><span class="field-suffix">FC</span></div></div>
                <div class="field"><label>Insurance Value</label><div class="field-suffix-wrap"><input type="number" id="isne_insValue" placeholder="0.00" step="0.01" value="@Model?.InsuranceValue"><span class="field-suffix">FC</span></div></div>

                <div class="fin-group-title">Indian Rupee Details</div>
                <div class="field"><label>Insurance Exchange Rate</label><input type="number" id="isne_insExRate" placeholder="0.00" step="0.0001" value="@Model?.InsuranceExRate"></div>
                <div class="field"><label>Insurance Rate</label><input type="number" id="isne_insRate" placeholder="0.000" step="0.001" value="@Model?.InsuranceRate"></div>
                <div class="field"><label>Insurance Value (INR)</label><div class="field-suffix-wrap"><input type="number" id="isne_insValueINR" placeholder="0.00" step="0.01" value="@Model?.InsuranceValueInr"><span class="field-suffix">₹</span></div></div>
                <div class="field"><label>CIF Value (INR)</label><div class="field-suffix-wrap"><input type="number" id="isne_cifINR" placeholder="0.00" step="0.01" value="@Model?.CifInr"><span class="field-suffix">₹</span></div></div>
                <div class="field"><label>Market Rate</label><input type="number" id="isne_marketRate" placeholder="0.00" step="0.01" value="@Model?.MarketRate"></div>
                <div class="field"><label>Market Value (INR)</label><div class="field-suffix-wrap"><input type="number" id="isne_marketValueINR" placeholder="0.00" step="0.01" value="@Model?.MarketValueInr"><span class="field-suffix">₹</span></div></div>
                <div class="field"><label>Gross Weight (KGS)</label><div class="field-suffix-wrap"><input type="number" id="isne_grossWt" placeholder="0.000" step="0.001" value="@Model?.GrossWeight"><span class="field-suffix">KG</span></div></div>
                <div class="field"><label>Net Weight (KGS)</label><div class="field-suffix-wrap"><input type="number" id="isne_netWt" placeholder="0.000" step="0.001" value="@Model?.NetWeight"><span class="field-suffix">KG</span></div></div>
                <div class="field"><label>LC Amount</label><div class="field-suffix-wrap"><input type="number" id="isne_lcAmount" placeholder="0.00" step="0.01" value="@Model?.LcAmount"><span class="field-suffix">FC</span></div></div>
                <div class="field"><label>Shipment Expiry Date</label><input type="date" id="isne_shipExpiry" value="@D(Model?.ShipmentExpiry)"></div>
                <div class="field">
                    <label>Partial Shipment Allowed</label>
                    <select id="isne_partialShipment">
                        @foreach (var p in new[] { "ALLOWED", "NOT ALLOWED", "PARTIAL" })
                        {
                            <option value="@p" selected="@((Model?.PartialShipment ?? "ALLOWED") == p)">@p</option>
                        }
                    </select>
                </div>
                <div class="field"><label>Duty Amount</label><div class="field-suffix-wrap"><input type="number" id="isne_dutyAmount" placeholder="0.00" step="0.01" value="@Model?.DutyAmount"><span class="field-suffix">₹</span></div></div>
            </div>
        </div>
    </div>

    <!-- Form Footer Buttons -->
    <div style="display:flex;gap:12px;justify-content:flex-end;padding-top:8px;">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('isneCancelBtn').click()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Cancel
        </button>
        <button type="button" class="btn btn-amber" onclick="document.getElementById('isneSaveBtn').click()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
            Save Job (F9)
        </button>
    </div>

</div>
</form>

@section Scripts {
    <script src="~/js/job-isne.js" asp-append-version="true"></script>
}
