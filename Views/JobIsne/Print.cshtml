@using CTD_FINAL.Entities
@model JobIsne
@{
    Layout = null;
    var fields = new (string Label, object? Value)[]
    {
        ("Job Date", Model.JobDate.ToString("d MMM yyyy")),
        ("Party Code", Model.PartyCode),
        ("Sub Agent", Model.SubAgentName),
        ("CTD Number", Model.CtdNumber),
        ("Vessel Name", Model.VesselName),
        ("Voyage No", Model.VoyageNo),
        ("Country of Origin", Model.CountryOrigin),
        ("Route of Transit", Model.RouteOfTransit),
        ("M B/L No", Model.MblNo),
        ("H B/L No", Model.HblNo),
        ("LC Number", Model.LcNo),
        ("Container No", Model.ContainerNo),
        ("No. of Packages", Model.NoPackages),
        ("Customs Code", Model.CustomsCode),
        ("Cargo Description", Model.CargoDescription),
        ("Currency", Model.Currency),
        ("Exchange Rate", Model.ExchangeRate),
        ("FOB Value", Model.FobValue),
        ("CIF FC", Model.CifFc),
        ("CIF INR", Model.CifInr),
        ("Gross Weight", Model.GrossWeight),
        ("Net Weight", Model.NetWeight),
        ("Duty Amount", Model.DutyAmount),
    };
}
<!DOCTYPE html>
<html>
<head>
    <title>Job ISNE - @Model.JobNumber</title>
    <style>
        body{font-family:Arial,sans-serif;padding:30px;color:#10172a;}
        h1{font-size:18px;margin-bottom:4px;} h2{font-size:14px;color:#555;font-weight:normal;margin-bottom:20px;}
        table{width:100%;border-collapse:collapse;margin-bottom:20px;} td,th{border:1px solid #ddd;padding:6px 10px;font-size:12px;} th{background:#11192e;color:#fff;text-align:left;}
    </style>
</head>
<body onload="window.print()">
    <h1>JOB — ISNE</h1>
    <h2>Job No: @Model.JobNumber &nbsp;|&nbsp; Party: @Model.PartyName</h2>
    <table>
        <tr><th>Field</th><th>Value</th></tr>
        @foreach (var f in fields)
        {
            <tr><td>@f.Label</td><td>@(f.Value ?? "—")</td></tr>
        }
    </table>
    <p style="font-size:11px;color:#999;">Printed from CTD Management System &middot; @DateTime.Now.ToString("g")</p>
</body>
</html>
