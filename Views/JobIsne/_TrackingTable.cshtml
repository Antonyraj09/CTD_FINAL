@using CTD_FINAL.DTOs
@using CTD_FINAL.Entities
@using CTD_FINAL.Helpers
@model PagedResult<JobIsne>
@{
    var sortKey = ViewData["SortKey"] as string ?? "jobDate";
    var sortDir = ViewData["SortDir"] as string ?? "desc";
    string SortIco(string key) => sortKey == key ? (sortDir == "asc" ? "↑" : "↓") : "↕";
}
<table class="data-table" id="trackingTable">
    <thead>
        <tr>
            <th class="sortable" data-sort="jobNo">Job No. <span class="sort-ico">@SortIco("jobNo")</span></th>
            <th class="sortable" data-sort="jobDate">Date <span class="sort-ico">@SortIco("jobDate")</span></th>
            <th class="sortable" data-sort="party">Party <span class="sort-ico">@SortIco("party")</span></th>
            <th>CTD No.</th>
            <th>Container</th>
            <th>Route of Transit</th>
            <th>Status</th>
            <th class="no-print">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="table-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <div>No jobs match your search criteria</div>
            </td></tr>
        }
        else
        {
            foreach (var j in Model.Items)
            {
                var status = JobIsneStatus.Label(j);
                <tr data-job-id="@j.Id">
                    <td class="cell-strong job-code">@j.JobNumber</td>
                    <td>@j.JobDate.ToString("d MMM yyyy")</td>
                    <td>@j.PartyName</td>
                    <td class="ctd-code">@(j.CtdNumber ?? "—")</td>
                    <td>@(j.Containers.Count switch { 0 => "—", 1 => j.Containers.First().ContainerNo ?? "—", var n => $"{n} containers" })</td>
                    <td>@(j.RouteOfTransit ?? "—")</td>
                    <td><span class="badge @JobIsneStatus.BadgeClass(status)">@status</span></td>
                    <td class="no-print">
                        <div class="row-actions">
                            <a class="iconbtn-table" asp-controller="JobIsne" asp-action="Index" asp-route-id="@j.Id" title="View / Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></a>
                            <a class="iconbtn-table" href="/JobIsne/Print/@j.Id" target="_blank" title="Print"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg></a>
                            <a class="iconbtn-table" href="/JobIsne/CtdSubmission/@j.Id" target="_blank" title="CTD Submission (Nepal)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg></a>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
<div class="table-foot">
    <span class="text-muted" id="trk_paginationInfo">
        @(Model.TotalCount > 0 ? $"Showing {((Model.Page - 1) * Model.PageSize) + 1}–{Math.Min(Model.Page * Model.PageSize, Model.TotalCount)} of {Model.TotalCount}" : "Showing 0–0 of 0")
    </span>
    <div class="pagination" id="trk_pagination">
        @for (int p = 1; p <= Model.TotalPages; p++)
        {
            <button type="button" class="page-btn @(p == Model.Page ? "active" : "")" data-page="@p">@p</button>
        }
    </div>
</div>
