@using System.Globalization
@using CTD_FINAL.Entities
@using CTD_FINAL.Helpers
@model JobIsne
@{
    Layout = null;
    var agent = ViewBag.Agent as SubAgent;
    var inr = CultureInfo.GetCultureInfo("en-IN");
    var plain = CultureInfo.InvariantCulture;

    string D(DateTime? d) => d?.ToString("dd/MM/yyyy") ?? "";
    string V(object? v) => v?.ToString() ?? "";

    var agentName = agent?.Name ?? Model.SubAgentName;
    var agentAddress = agent is null
        ? null
        : string.Join(", ", new[] { agent.AddressLine1, agent.AddressLine2, string.Join(" - ", new[] { agent.City, agent.PinCode }.Where(s => !string.IsNullOrWhiteSpace(s))) }
            .Where(s => !string.IsNullOrWhiteSpace(s)));

    var importerAddress = string.Join(" ", new[] { Model.PartyName, Model.Address }.Where(s => !string.IsNullOrWhiteSpace(s)));

    // Bond amount is the difference between market value and CIF value — the reference
    // form's own condition clause (1) spells this out ("the difference between the market
    // value of the goods in India and their CIF value"), and the reference sample's figures
    // confirm it exactly: 78,32,780.00 - 44,75,874.00 = 33,56,906.00.
    var bondAmount = (Model.MarketValueInr ?? 0) - (Model.CifInr ?? 0);
    var bondAmountWords = IndianNumberWords.ToWords(bondAmount);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Undertaking Bond - @Model.JobNumber</title>
    <style>
        /* Page size/margins taken from the reference form's own Word document (pgSz/pgMar in
           word/document.xml). The reference's ~90mm of blank paragraphs before "To" (on top
           of an already-large 33.87mm top margin) reads as space reserved for a pre-printed
           company letterhead — reproduced as a spacer rather than invented letterhead content
           we have no reference for. */
        @@page { size: A4; margin: 33.87mm 19.98mm 4.94mm 4.99mm; }
        body { font-family: Arial, Helvetica, sans-serif; color: #000; font-size: 11pt; line-height: 1.25; margin: 0; }
        p { margin: 0 0 4mm; }
        .f10 { font-size: 10pt; }
        .top-spacer { height: 90mm; }
        .gap-lg { margin-top: 20mm; }
        .gap-md { margin-top: 9mm; }
        .center { text-align: center; }
        .sched-title { text-align: center; margin: 9mm 0 6mm; }
        .sched-field { margin: 0 0 4mm; }
        .item-line { margin: 0 0 4mm; }
        .conditions { list-style: none; counter-reset: cond; margin: 0; padding-left: 6mm; }
        .conditions li { counter-increment: cond; margin: 0 0 4mm; padding-left: 4mm; text-indent: -4mm; }
        .conditions li::before { content: "(" counter(cond) ") "; }
        .narrow { max-width: 90mm; }
        @@media print { .no-print { display: none; } }
    </style>
</head>
<body onload="window.print()">
    <div class="top-spacer"></div>

    <p>To</p>
    <p>The President of India Commissioner of Customs (Port) Nepal Unit/Section, Custom House Kolkata</p>

    <p class="gap-lg">UNDERTAKING</p>

    <p class="gap-lg">@V(Model.JobNumber)</p>

    <p class="gap-md f10">KNOW ALL MEN BY THESE PRESENTS THAT WE, @V(agentName)</p>
    <p class="f10">OF @V(agentAddress) Hereinafter called the Customs Clearing</p>
    <p class="f10">Agent on behalf of importer <b>@V(Model.PartyName)</b> &nbsp;&nbsp;&nbsp; <b>Nepal</b></p>
    <p class="f10">(which expression include its successor/ heirs, executors, adminstrators &amp; legal representative) are held and firmly bond upto the President of India hereinafter called the <b>"President"</b>(which expression shall include his successors</p>
    <p class="f10">and assigns) in the sum of Rs. <b>@bondAmount.ToString("N2", inr)</b></p>
    <p>(Rupees @bondAmountWords)</p>
    <p>to be paid to the President for which payment well and truly to be made, WE bind ourselves, our successors, heirs, executors, adminstrators and legal representatives firmly by these present. Sealed with our seals this.</p>

    <p class="gap-md">WHEREAS</p>
    <p>The Commissioner of Customs, Custom House, Kolkata ( hereinafter called the<b>"Proper Officer"</b>has agreed to allow transit of the goods in terms of para 9A of the Importer procedure of the memorandum to the protocol to the treaty of transit between Nepal and India - 1999 (hereinafter referred to as treaty).</p>

    <p class="sched-title">SCHEDULE</p>

    <p class="sched-field f10">CTD NO. : <b>@V(Model.CtdNumber)</b></p>
    <p class="sched-field f10">DATE : <b>@D(Model.CtdDate)</b></p>

    <p class="sched-field f10">CHA'S NAME : @V(agentName) &amp; ADDRESS: @V(agentAddress)</p>

    <p class="sched-field">Importer's Name &amp; Address:<br />@importerAddress</p>
    <p class="sched-field f10"><b>EXIM: @V(Model.ImporterCode)</b></p>

    <p class="sched-field f10">M.V. :<br />@V(Model.VesselName)</p>
    <p class="sched-field f10">Rot.No.: <b>@V(Model.RotNo)</b></p>
    <p class="sched-field f10">Line No. <b>@V(Model.LineNo)</b></p>

    <p class="sched-field f10">CIF Value : <b>@((Model.CifInr ?? 0).ToString("N2", plain))</b></p>
    <p class="sched-field">Quantity &amp; Description of Goods</p>
    <p class="sched-field">Market Value :<br /><b>@((Model.MarketValueInr ?? 0).ToString("N2", inr))</b></p>

    @{ var itemNo = 0; }
    @foreach (var c in Model.Containers)
    {
        itemNo++;
        <p class="item-line f10">@itemNo 1X@(c.ContainerSize.TrimEnd('t', 'f'))' CONT. STC @c.NoPackages PKG@(itemNo == Model.Containers.Count ? " " + V(Model.CargoDescription ?? Model.MiscDescription) : "")</p>
    }
    @if (!Model.Containers.Any())
    {
        <p class="item-line f10">1 @V(Model.CargoDescription ?? Model.MiscDescription)</p>
    }

    <p class="sched-field f10">QTY. :<br /><b>@(Model.GrossWeight.HasValue ? Model.GrossWeight.Value.ToString("N3", plain) : "")</b><br />KGS.</p>

    <p class="gap-md">Amount payable in terms of para 9A of the treaty as above.</p>
    <p>NOW THE CONDITION of the above written undertaking is such that :-</p>
    <ol class="conditions f10">
        <li>The Importer shall pay the amount equal to the difference between the market value of the goods in India and their CIF value on demand to the Commissioner of Customs, Kolkata in the event of the goods not reaching Nepal, in terms of para 9A and 9b of Import Procedure of the said treaty.</li>
        <li>The President through the Commissioner of Customs Kolkata or other officer may recover the said sum</li>
    </ol>

    <p>Rs.<br /><b>@bondAmount.ToString("N2", inr)</b><br />( Rupees :<b>@bondAmountWords</b>)</p>
    <p>in terms Para 9A in the manner prescribed under Para 9A and 9B of the Import procedure of the memorandum to the protocol to the treaty of transit between Nepal and India effective from 6th January, 1999 and/or by other laws enforceable, if any.</p>

    <p class="gap-md">IN WITNESS WHEREOF the Importer has herein set and subscribed its hands and seals the day, month and year first above written.</p>

    <p class="gap-md narrow">SIGNED AND DELIVERED by and on behalf of the Importer at Calcutta</p>
    <p>in the presence of : 1.</p>
    <p>2.</p>

    <p class="center gap-md">Accepted</p>
    <p class="center">for &amp; on behalf of the President of India (Designation of the authorised officer)</p>
    <p class="center">in the presence of</p>
</body>
</html>
