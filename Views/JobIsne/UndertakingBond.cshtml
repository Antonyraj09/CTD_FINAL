@using System.Globalization
@using CTD_FINAL.Entities
@using CTD_FINAL.Helpers
@model JobIsne
@{
    Layout = null;
    var agent = ViewBag.Agent as SubAgent;
    var inr = CultureInfo.GetCultureInfo("en-IN");
    var plain = CultureInfo.InvariantCulture;

    string D(DateTime? d) => d?.ToString("dd/MM/yyyy") ?? "";
    string V(object? v) => v?.ToString() ?? "";

    var agentName = agent?.Name ?? Model.SubAgentName;
    var agentAddress = agent is null
        ? null
        : string.Join(", ", new[] { agent.AddressLine1, agent.AddressLine2, string.Join(" - ", new[] { agent.City, agent.PinCode }.Where(s => !string.IsNullOrWhiteSpace(s))) }
            .Where(s => !string.IsNullOrWhiteSpace(s)));

    var importerAddress = string.Join(" ", new[] { Model.PartyName, Model.Address }.Where(s => !string.IsNullOrWhiteSpace(s)));

    // Bond amount is the difference between market value and CIF value — the reference
    // form's own condition clause (1) spells this out ("the difference between the market
    // value of the goods in India and their CIF value"), and the reference sample's figures
    // confirm it exactly: 78,32,780.00 - 44,75,874.00 = 33,56,906.00.
    var bondAmount = (Model.MarketValueInr ?? 0) - (Model.CifInr ?? 0);
    var bondAmountWords = IndianNumberWords.ToWords(bondAmount);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Undertaking Bond - @Model.JobNumber</title>
    <style>
        /* Every dimension below — page margins, and every paragraph's margin-top and font
           size — is read directly from the reference form's own word/document.xml
           (pgMar; each paragraph's spacing/before + its run's sz, converted from twips/
           half-points), not estimated: the reference is pure flowing text with no tables,
           so exact paragraph-to-paragraph spacing is the only thing that reproduces its
           layout faithfully. Blank paragraphs in the source (no visible text) contribute
           their own line height to the following paragraph's margin-top rather than being
           rendered as empty elements. */
        @@page { size: A4; margin: 33.87mm 19.98mm 4.94mm 4.99mm; }
        body { font-family: Arial, Helvetica, sans-serif; color: #000; font-size: 11pt; line-height: 1.15; margin: 0; }
        p { margin: 0; }
        .f10 { font-size: 10pt; }
        .center { text-align: center; }
        .narrow { max-width: 90mm; }
        /* Page 2 begins with SCHEDULE, per the reference layout, and the whole schedule
           block (title through QTY/KGS) is kept from splitting across pages 2/3. */
        .schedule-page { break-before: page; page-break-before: always; }
        .schedule-block { break-inside: avoid; page-break-inside: avoid; }
        .conditions { list-style: none; counter-reset: cond; margin: 9.35mm 0 0; padding-left: 6mm; }
        .conditions li { counter-increment: cond; margin: 0 0 5mm; padding-left: 4mm; text-indent: -4mm; }
        .conditions li:first-child { margin-top: 0; }
        .conditions li::before { content: "(" counter(cond) ") "; }
        @@media print { .no-print { display: none; } }
    </style>
</head>
<body onload="window.print()">
    <!-- ============ PAGE 1: everything up to (not including) SCHEDULE ============ -->
    <p style="margin-top:99.82mm;">To</p>
    <p style="margin-top:2.31mm;">The President of India Commissioner of Customs (Port) Nepal Unit/Section, Custom House Kolkata</p>

    <p style="margin-top:16.21mm;">UNDERTAKING</p>

    <p style="margin-top:13.9mm;">@V(Model.JobNumber)</p>

    <p class="f10" style="margin-top:8.42mm;">KNOW ALL MEN BY THESE PRESENTS THAT WE, @V(agentName)</p>
    <p style="margin-top:2.67mm;">OF @V(agentAddress) Hereinafter called the Customs Clearing</p>
    <p class="f10" style="margin-top:2.39mm;">Agent on behalf of importer <b>@V(Model.PartyName)</b> &nbsp;&nbsp;&nbsp; <b>Nepal</b></p>
    <p style="margin-top:2.47mm;">(which expression include its successor/ heirs, executors, adminstrators &amp; legal representative) are held and firmly bond upto the President of India hereinafter called the <b>"President"</b>(which expression shall include his successors</p>
    <p class="f10" style="margin-top:2.11mm;">and assigns) in the sum of Rs. <b>@bondAmount.ToString("N2", inr)</b></p>
    <p style="margin-top:2.31mm;">(Rupees @bondAmountWords)</p>
    <p style="margin-top:2.77mm;">to be paid to the President for which payment well and truly to be made, WE bind ourselves, our successors, heirs, executors, adminstrators and legal representatives firmly by these present. Sealed with our seals this.</p>

    <p style="margin-top:4.63mm;">WHEREAS</p>
    <p style="margin-top:3.97mm;">The Commissioner of Customs, Custom House, Kolkata ( hereinafter called the<b>"Proper Officer"</b>has agreed to allow transit of the goods in terms of para 9A of the Importer procedure of the memorandum to the protocol to the treaty of transit between Nepal and India - 1999 (hereinafter referred to as treaty).</p>

    <!-- ============ PAGE 2: SCHEDULE (kept together, starts a fresh page) ============ -->
    <div class="schedule-page">
        <div class="schedule-block">
            <p class="center" style="margin-top:10.37mm;">SCHEDULE</p>

            <p class="f10" style="margin-top:16.23mm;">CTD NO. : <b>@V(Model.CtdNumber)</b></p>
            <p class="f10" style="margin-top:5.7mm;">DATE : <b>@D(Model.CtdDate)</b></p>

            <p class="f10" style="margin-top:9.08mm;">CHA'S NAME : @V(agentName) &amp; ADDRESS: @V(agentAddress)</p>

            <p style="margin-top:10.97mm;">Importer's Name &amp; Address:<br />@importerAddress</p>
            <p class="f10" style="margin-top:4.83mm;"><b>EXIM: @V(Model.ImporterCode)</b></p>

            <p class="f10" style="margin-top:11.1mm;">M.V. :<br />@V(Model.VesselName)</p>
            <p class="f10" style="margin-top:6.35mm;">Rot.No.: <b>@V(Model.RotNo)</b></p>
            <p class="f10" style="margin-top:6.86mm;">Line No. <b>@V(Model.LineNo)</b></p>

            <p class="f10" style="margin-top:10.34mm;">CIF Value : <b>@((Model.CifInr ?? 0).ToString("N2", plain))</b></p>
            <p style="margin-top:6.63mm;">Quantity &amp; Description of Goods</p>
            <p style="margin-top:6.74mm;">Market Value :<br /><b>@((Model.MarketValueInr ?? 0).ToString("N2", inr))</b></p>

            @{ var itemNo = 0; }
            @foreach (var c in Model.Containers)
            {
                itemNo++;
                <p class="f10" style="margin-top:11.89mm;">@itemNo 1X@(c.ContainerSize.TrimEnd('t', 'f'))' CONT. STC @c.NoPackages PKG@(itemNo == Model.Containers.Count ? " " + V(Model.CargoDescription ?? Model.MiscDescription) : "")</p>
            }
            @if (!Model.Containers.Any())
            {
                <p class="f10" style="margin-top:11.89mm;">1 @V(Model.CargoDescription ?? Model.MiscDescription)</p>
            }

            <p class="f10" style="margin-top:9.35mm;">QTY. :<br /><b>@(Model.GrossWeight.HasValue ? Model.GrossWeight.Value.ToString("N3", plain) : "")</b><br />KGS.</p>
        </div>

        <p class="f10" style="margin-top:13.39mm;">Amount payable in terms of para 9A of the treaty as above.</p>
        <p style="margin-top:6.76mm;">NOW THE CONDITION of the above written undertaking is such that :-</p>
        <ol class="conditions f10">
            <li>The Importer shall pay the amount equal to the difference between the market value of the goods in India and their CIF value on demand to the Commissioner of Customs, Kolkata in the event of the goods not reaching Nepal, in terms of para 9A and 9b of Import Procedure of the said treaty.</li>
            <li>The President through the Commissioner of Customs Kolkata or other officer may recover the said sum</li>
        </ol>

        <p style="margin-top:9.61mm;">Rs.<br /><b class="f10">@bondAmount.ToString("N2", inr)</b><br /><span class="f10">( Rupees :<b>@bondAmountWords</b>)</span></p>
        <p style="margin-top:9.07mm;">in terms Para 9A in the manner prescribed under Para 9A and 9B of the Import procedure of the memorandum to the protocol to the treaty of transit between Nepal and India effective from 6th January, 1999 and/or by</p>
        <p style="margin-top:4.46mm;">other laws enforceable, if any.</p>

        <p style="margin-top:8.93mm;">IN WITNESS WHEREOF the Importer has herein set and subscribed its hands and seals the day, month and year first above written.</p>

        <p class="narrow" style="margin-top:13.39mm;">SIGNED AND DELIVERED by and on behalf of the Importer at Calcutta</p>
        <p style="margin-top:4.5mm;">in the presence of : 1.</p>
        <p style="margin-top:6.54mm;">2.</p>

        <p class="center" style="margin-top:13.39mm;">Accepted</p>
        <p class="center" style="margin-top:4.96mm;">for &amp; on behalf of the President of India (Designation of the authorised officer)</p>
        <p class="center" style="margin-top:4.46mm;">in the presence of</p>
    </div>
</body>
</html>
