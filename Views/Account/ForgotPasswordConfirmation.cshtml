@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Check Your Request";
}
<div class="auth-shell" style="grid-template-columns:1fr;max-width:480px;">
    <div class="auth-form-panel" style="align-items:center;text-align:center;">
        <div class="brand-mark" style="margin:0 auto 20px;background:linear-gradient(135deg,var(--transit-green),var(--transit-green-light));">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#042013" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
        </div>
        <h1>Request received</h1>
        <p class="auth-sub">If an account exists for that email, our team will follow up with reset instructions shortly.</p>
        <a class="btn btn-amber" asp-controller="Account" asp-action="Login">Back to Sign In</a>
    </div>
</div>
