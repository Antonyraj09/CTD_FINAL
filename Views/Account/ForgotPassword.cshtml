@model CTD_FINAL.Models.Account.ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}
<div class="auth-shell" style="grid-template-columns:1fr;max-width:480px;">
    <div class="auth-form-panel">
        <h1>Forgot your password?</h1>
        <p class="auth-sub">Enter your account email and we'll send you reset instructions.</p>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="auth-validation-summary" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

            <div class="auth-field">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" autocomplete="email" autofocus placeholder="you@company.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-amber auth-submit">Send Reset Instructions</button>
        </form>

        <a class="auth-back-link" asp-controller="Account" asp-action="Login">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            Back to Sign In
        </a>

        <div class="auth-demo-note">
            Outbound email delivery is not configured in this environment, so reset requests are logged rather than emailed. Contact your administrator to reset a password from the Users &amp; Roles screen.
        </div>
    </div>
</div>
