@using CTD_FINAL.Entities
@{
    ViewData["Title"] = "CTD Tracking";
    var importers = (IReadOnlyList<Importer>)ViewBag.Importers;
}
<div class="section-head">
    <div>
        <h2>CTD Tracking</h2>
        <p>Search and monitor every transit job from creation to delivery</p>
    </div>
    <div class="section-actions">
        <a class="btn btn-amber btn-sm" asp-controller="Jobs" asp-action="Wizard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
            New CTD Job
        </a>
    </div>
</div>

<div class="panel" style="margin-bottom:18px;">
    <div class="panel-body">
        <div class="form-grid cols-4">
            <div class="field"><label>Job Number</label><input type="text" id="trk_jobNo" placeholder="CTD-2026-0001"></div>
            <div class="field"><label>CTD Number</label><input type="text" id="trk_ctdNo" placeholder="EDI / Manual CTD No."></div>
            <div class="field"><label>Importer</label>
                <select id="trk_importer"><option value="">All Importers</option>@foreach (var i in importers){<option value="@i.Id">@i.Name</option>}</select>
            </div>
            <div class="field"><label>Container Number</label><input type="text" id="trk_container" placeholder="e.g. MSKU1234567"></div>
            <div class="field"><label>From Date</label><input type="date" id="trk_dateFrom"></div>
            <div class="field"><label>To Date</label><input type="date" id="trk_dateTo"></div>
            <div class="field"><label>Status</label>
                <select id="trk_status">
                    <option value="">All Statuses</option>
                    <option>Draft</option><option>Submitted</option><option>Approved</option><option>Transit</option><option>Delivered</option><option>Closed</option>
                </select>
            </div>
            <div class="field" style="justify-content:flex-end;flex-direction:row;align-items:flex-end;gap:8px;">
                <button class="btn btn-primary btn-block" id="trk_searchBtn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>Search</button>
                <button class="btn btn-ghost" id="trk_clearBtn" title="Clear filters"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m5 0V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2"/></svg></button>
            </div>
        </div>
    </div>
</div>

<div class="panel">
    <div class="table-toolbar">
        <div class="table-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="text" id="trk_quickSearch" placeholder="Quick filter…">
        </div>
        <div class="table-filters">
            <span class="tag-chip" id="trk_resultCount">0 jobs</span>
            <div class="export-bar">
                <button class="btn btn-outline btn-xs" data-export="excel" data-table="#trackingTable" data-title="CTD Tracking"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>Excel</button>
                <button class="btn btn-outline btn-xs" data-export="pdf" data-table="#trackingTable" data-title="CTD Tracking"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>PDF</button>
                <button class="btn btn-outline btn-xs" data-action="printTable" data-table="#trackingTable" data-title="CTD Tracking"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>Print</button>
            </div>
        </div>
    </div>
    <div class="table-scroll" id="trackingTableContainer">
        <!-- loaded via AJAX -->
    </div>
</div>

@section Scripts {
    <script src="~/js/tracking.js" asp-append-version="true"></script>
}
